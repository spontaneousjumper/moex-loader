{
  "name": "moex-loader",
  "packageManager": "yarn@4.9.2",
  "main": "electron/main.js",
  "scripts": {
    "build": "npm run build --prefix renderer",
    "build:electron": "tsc -p electron/tsconfig.json",
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "npm run dev --prefix renderer",
    "dev:electron": "npm run build:electron && wait-on http://localhost:5173 && electron dist-electron/main.js"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "wait-on": "^9.0.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
